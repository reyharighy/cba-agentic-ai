# ---- Paths & Runtime ----
WORKDIR_PATH=/var/www/cba-agentic-ai

# ---- Agent API ----
AGENT_API_PORT=8000

# ---- PostgreSQL (Business / External OLTP) ----
BUSINESS_POSTGRES_HOST=pgsql-business
BUSINESS_POSTGRES_PORT=5432
BUSINESS_POSTGRES_USER=cba_business
BUSINESS_POSTGRES_PASSWORD=password
BUSINESS_POSTGRES_DB=business
BUSINESS_POSTGRES_HOST_PORT=5432

# ---- PostgreSQL (Agent / Internal Memory) ----
AGENT_POSTGRES_HOST=pgsql-agent
AGENT_POSTGRES_PORT=5432
AGENT_POSTGRES_USER=cba_agent
AGENT_POSTGRES_PASSWORD=password
AGENT_POSTGRES_DB=agent_memory
AGENT_POSTGRES_HOST_PORT=5433

# ---- pgAdmin (optional) ----
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=password

# ---- External DB Seeding ----
# Set to true to populate PostgreSQL with synthetic business data
ENABLE_EXTERNAL_DB_SEEDING=true

# ---- LLM / Tooling APIs ----
GROQ_API_KEY=your_groq_api_key_here
E2B_API_KEY=your_e2b_api_key_here

# ---- Observability (Optional) ----
LANGSMITH_TRACING_V2=false
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_WORKSPACE_ID=your_workspace_id_here

# ---- Scenario test hooks (branch test/loop-correction; default false) ----
SCENARIO_TEST_FORCE_DATA_RETRIEVAL_RETRY_ONCE=false
SCENARIO_TEST_FORCE_ANALYTICAL_RETRY_ONCE=false
SCENARIO_TEST_FORCE_DATA_RETRIEVAL_INTERRUPT=false
